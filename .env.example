VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Same values as above — optional but recommended on Vercel for /api serverless
# (Node does not receive Vite import.meta.env; process.env fallbacks in src/lib/config.ts)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-only (do not prefix with VITE_)
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
# Optional: override default claude-haiku-4-5-20251001 if API returns 400 (model access)
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
RESEND_API_KEY=
RESEND_FROM=newsletter@mail.footballwire.uk
ADMIN_ALERT_EMAIL=

# Cron: Authorization: Bearer <value> for /api/cron/run-pipeline (GET/POST). Alias: VERCEL_CRON_SECRET
CRON_SECRET=
