{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/cron/run-pipeline",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/send-newsletters",
      "schedule": "45 6 * * *"
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
